# Copy this file to backend/.env and fill in the real values.
# backend/.env is gitignored and must NEVER be committed.

# Challonge v1 API key — from connect.challonge.com → "Migrated APIv1 Key" app → api_v1_key field
# This is the primary auth used for fetching tournament data via /v1/ endpoints.
CHALLONGE_V1_KEY=your_v1_api_key_here

# Challonge OAuth credentials (Neos City app — only used as fallback if CHALLONGE_V1_KEY is unset)
CHALLONGE_CLIENT_ID=your_client_id_here
CHALLONGE_CLIENT_SECRET=your_client_secret_here

# PostgreSQL / Supabase connection string
# Use the Session pooler (IPv4) hostname: aws-<region>.pooler.supabase.com:5432
# User portion is postgres.<project_ref>, not plain postgres.
DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# start.gg personal access token — from start.gg → Admin → Developer Settings → Personal Access Tokens
STARTGG_TOKEN=your_startgg_token_here

# YouTube Data API v3 key — powers the YouTube Creators page (recent uploads +
# featured spotlight). Create at console.cloud.google.com → APIs & Services →
# Credentials, then enable "YouTube Data API v3". Used only by the background
# poller + refresh_creators.js, never on the request path.
YOUTUBE_API_KEY=your_youtube_api_key_here
# Background poller (backend/src/services/poller.js) cadence. Optional — defaults
# shown. Polling is disabled entirely when YOUTUBE_API_KEY is unset.
CREATOR_POLL_HOURS=6
CREATOR_POLL_ON_BOOT=true

# JWT secret — signs user session tokens + the OAuth `state` tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_string

# Login is OAuth-only (Discord + Google). Add each redirect URI below to the
# provider's allowed-redirects list — they must match exactly.

# Discord OAuth — from discord.com/developers → your app → OAuth2 → Redirects.
#   dev:  http://localhost:3001/api/auth/discord/callback
#   prod: https://api.neos-city.com/api/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback

# Google OAuth — from console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID (Web application). Scopes openid/email/profile (non-sensitive,
# no Google review). Add the callback to "Authorized redirect URIs".
#   dev:  http://localhost:3001/api/auth/google/callback
#   prod: https://api.neos-city.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Admin token gating mutating routes (POST /api/tournaments/import*, /api/organizers POST/DELETE/sync/discover).
# Generate with: openssl rand -hex 32
# Clients send it as the `x-admin-token` header. Required in all environments —
# requests fail closed with 503 if this is unset on the server.
ADMIN_TOKEN=generate_a_long_random_token_here
