# Copy this file to backend/.env and fill in the real values.
# backend/.env is gitignored and must NEVER be committed.

# Challonge v1 API key — from connect.challonge.com → "Migrated APIv1 Key" app → api_v1_key field
# This is the primary auth used for fetching tournament data via /v1/ endpoints.
CHALLONGE_V1_KEY=your_v1_api_key_here

# Challonge OAuth credentials (Neos City app — only used as fallback if CHALLONGE_V1_KEY is unset)
CHALLONGE_CLIENT_ID=your_client_id_here
CHALLONGE_CLIENT_SECRET=your_client_secret_here

# PostgreSQL / Supabase connection string
# Use the Session pooler (IPv4) hostname: aws-<region>.pooler.supabase.com:5432
# User portion is postgres.<project_ref>, not plain postgres.
DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# start.gg personal access token — from start.gg → Admin → Developer Settings → Personal Access Tokens
STARTGG_TOKEN=your_startgg_token_here

# JWT secret (set this to a random string for any future auth work)
JWT_SECRET=change_this_to_a_random_string

# Admin token gating mutating routes (POST /api/tournaments/import*, /api/organizers POST/DELETE/sync/discover).
# Generate with: openssl rand -hex 32
# Clients send it as the `x-admin-token` header. Required in all environments —
# requests fail closed with 503 if this is unset on the server.
ADMIN_TOKEN=generate_a_long_random_token_here
