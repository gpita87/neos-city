# ========================================================================
# Dependencies
# ========================================================================
node_modules/
**/node_modules/

# ========================================================================
# Secrets & local environment
# Never commit .env files. Use .env.example to document required variables.
# ========================================================================
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# ========================================================================
# Build output
# ========================================================================
dist/
build/
.next/
out/
**/dist/
**/build/

# ========================================================================
# Logs
# ========================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ========================================================================
# Editors / IDEs
# ========================================================================
# JetBrains: track shared IDE config (.idea/), ignore per-user files
# (.idea/.gitignore inside the folder already handles this granularly)
.vscode/
*.swp
*.swo
*~

# ========================================================================
# OS junk
# ========================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ========================================================================
# Office lock files (Excel, Word, etc. open in another window)
# ========================================================================
.~lock.*#
~$*

# ========================================================================
# Mid-edit backup files left behind by truncation recoveries
# (see AGENT_CONTEXT.md "tournaments.js was truncated mid-edit" note)
# ========================================================================
*.before_repair
*.before_repair*
*.before_iframe
*.before_iframe*
*.bak
*.orig

# ========================================================================
# Coverage / test output
# ========================================================================
coverage/
.nyc_output/

# ========================================================================
# Database backups (created by backup_db.js)
# Logical Postgres dumps - never commit these.
# ========================================================================
backups/

# ========================================================================
# Misc local-only files
# ========================================================================
.cache/
.tmp/
tmp/

# ========================================================================
# Per-worktree ephemeral files (see AGENT_CONTEXT.md "Multi-agent worktree workflow")
# WORKTREE_SUMMARY.md is the per-agent writeup. It exists only inside
# worktrees spawned by spawn-worktree.js and is read by merge-worktree.js
# at merge time. It should never land in main's history.
# ========================================================================
WORKTREE_SUMMARY.md

# ========================================================================
# Claude Code per-machine overrides
# .claude/settings.json IS tracked (shared project permissions).
# .claude/settings.local.json is per-machine and must stay local.
# ========================================================================
.claude/settings.local.json
